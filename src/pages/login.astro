---
const error = Astro.url.searchParams.get('error') === '1';
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Login | Ben Gilmour</title>
    <style>
      body { margin: 0; min-height: 100vh; display: grid; place-items: center; font-family: Inter, system-ui, sans-serif; background: linear-gradient(180deg, #eff6ff 0%, #f8fafc 100%); }
      .card { width: min(520px, calc(100vw - 32px)); background: white; border-radius: 28px; padding: 32px; box-shadow: 0 24px 60px rgba(15, 23, 42, 0.09); }
      h1 { margin: 0 0 16px; font-size: clamp(2rem, 2.5vw, 2.5rem); }
      p { margin: 0 0 24px; color: #475569; }
      .field { display: grid; gap: 10px; margin-bottom: 18px; }
      label { font-weight: 600; color: #0f172a; }
      input { width: 100%; border: 1px solid #cbd5e1; border-radius: 14px; padding: 14px 16px; font-size: 1rem; font-family: inherit; }
      button { width: 100%; border: none; border-radius: 14px; padding: 14px 18px; font-size: 1rem; font-weight: 700; color: white; background: #4338ca; cursor: pointer; }
      button:hover { background: #312e81; }
      .error { margin-bottom: 16px; color: #dc2626; font-weight: 600; }
    </style>
  </head>
  <body>
    <main class="card">
      <h1>Admin login</h1>
      <p>Enter the site administrator credentials to manage sermons, blogs, and images.</p>
      {error ? <div class="error">Invalid username or password.</div> : null}
      <form method="post" action="/api/login">
        <div class="field">
          <label for="username">Username</label>
          <input id="username" name="username" type="text" required autocomplete="username" />
        </div>
        <div class="field">
          <label for="password">Password</label>
          <input id="password" name="password" type="password" required autocomplete="current-password" />
        </div>
        <button type="submit">Sign in</button>
      </form>
    </main>
  </body>
</html>
